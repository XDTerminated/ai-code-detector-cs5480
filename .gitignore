# ---------- Python ----------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
*.egg

# ---------- Virtual environments ----------
.venv/
venv/
env/
ENV/

# ---------- uv ----------
# uv.lock is committed; the cache is not.
.uv_cache/

# ---------- Editors / IDEs ----------
.vscode/
.idea/
*.swp
*.swo

# ---------- Jupyter ----------
.ipynb_checkpoints/
*.ipynb_checkpoints

# ---------- OS ----------
.DS_Store
Thumbs.db

# ---------- Project: data ----------
# Raw data must be downloaded per README; never commit it.
data/raw/*
data/interim/*
data/processed/*
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep

# ---------- Project: artifacts ----------
# Reports figures are regenerated; keep dir but ignore contents.
reports/figures/*
!reports/figures/.gitkeep

# Model checkpoints and logs
models/
checkpoints/
runs/
wandb/
mlruns/
logs/
*.ckpt
*.pt
*.pth
*.bin
*.safetensors

# HuggingFace cache (when pinned locally)
.cache/
hf_cache/
